<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KKN Kuliner Nusantara Tegal</title>

    <!-- === PUSTAKA EKSTERNAL === -->
    <script src="https://js.xendit.co/v1/xendit.min.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-database-compat.js"></script>

    <!-- === GAYA TAMPILAN === -->
    <style>
        * {margin:0; padding:0; box-sizing:border-box; font-family:"Segoe UI", sans-serif;}
        
        body {
            background:linear-gradient(180deg, #fff9e6 0%, #ffe4b5 50%, #f8d7a0 100%);
            min-height:100vh; padding:20px; position:relative;
        }

        /* === ORNAMEN KHAS TEGAL & JEPANG === */
        .hiasan-atas {
            position:fixed; top:0; left:0; right:0; height:12px;
            background:repeating-linear-gradient(90deg, #c8102e, #c8102e 30px, #ffffff 30px, #ffffff 60px);
            z-index:999;
        }
        .hiasan-bawah {
            position:fixed; bottom:0; left:0; right:0; height:12px;
            background:repeating-linear-gradient(90deg, #006837, #006837 30px, #ffffff 30px, #ffffff 60px);
            z-index:999;
        }
        .awan-jepang {
            position:absolute; top:80px; right:20px; font-size:80px; opacity:0.15; color:#c8102e;
        }
        .garis-pabrik {
            position:absolute; top:100px; left:15px; width:3px; height:90px;
            background:linear-gradient(#555, #888); border-radius:2px;
        }
        .asap-pabrik {
            position:absolute; top:85px; left:6px; font-size:28px; color:#666; opacity:0.4;
        }

        /* === KOTAK UTAMA === */
        .kotak-utama {
            max-width:480px; margin:60px auto 30px; background:white;
            border-radius:18px; padding:25px;
            border:4px solid transparent;
            border-image:linear-gradient(135deg, #c8102e, #ffb300, #006837) 1;
            box-shadow:0 8px 25px rgba(139,69,19,0.2); position:relative; z-index:10;
        }

        /* === HEADER TEMA KHAS TEGAL === */
        .header-tema {text-align:center; margin-bottom:20px;}
        .logo-tegal {font-size:55px; margin-bottom:8px;}
        .judul-utama {
            font-size:22px; font-weight:900;
            background:linear-gradient(90deg, #c8102e, #006837);
            -webkit-background-clip:text; color:transparent;
        }
        .sub-judul {
            font-size:14px; color:#8b4513; margin-top:4px; font-style:italic;
        }
        .slogan {
            font-size:13px; color:#c8102e; font-weight:bold; margin-top:6px;
            background:#fff3cd; display:inline-block; padding:4px 12px; border-radius:20px;
        }

        /* === CIRI KHAS: TEH POCI & PABRIK === */
        .ikon-khas {
            display:flex; justify-content:center; gap:25px; margin:15px 0; font-size:35px;
        }
        .label-ikon {font-size:11px; text-align:center; color:#555; margin-top:-5px;}

        .pemisah {
            display:flex; align-items:center; gap:10px; margin:18px 0; color:#8b4513; font-weight:500;
        }
        .garis {flex:1; height:2px; background:#e0c097;}

        /* === INFO RINGKAS === */
        .info-ringkas {
            display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:20px;
        }
        .kotak-info {
            background:#fffbf5; padding:15px; border-radius:10px; text-align:center;
            border-left:3px solid #ffb300;
        }
        .kotak-info .angka {font-size:22px; font-weight:bold; color:#c8102e; margin:5px 0;}
        .kotak-info .label {font-size:14px; color:#666;}

        /* === PILIHAN PERAN === */
        .pilihan-peran {display:grid; gap:12px; margin-bottom:20px;}
        .kotak-peran {
            border:2px solid #e8d5b7; border-radius:12px; padding:15px; cursor:pointer;
            transition:0.3s; background:#fffbf5;
            display:flex; align-items:center; gap:12px;
        }
        .kotak-peran:hover {
            border-color:#c8102e; transform:translateY(-2px);
            box-shadow:0 4px 12px rgba(200,16,46,0.15);
            background:linear-gradient(90deg, #fff5f5, #fffbf5);
        }
        .kotak-peran.terpilih {border-color:#006837; background:#f0fff4;}
        .ikon-peran {font-size:32px; width:45px; text-align:center;}
        .teks-peran h4 {font-size:16px; color:#333;}
        .teks-peran p {font-size:13px; color:#777;}

        /* === FORM & BAGIAN LAIN === */
        .form-grup {margin-bottom:14px;}
        label {
            display:block; font-size:14px; font-weight:600; color:#5a3817; margin-bottom:5px;
        }
        input, select {
            width:100%; padding:12px 15px; border:2px solid #e8d5b7; border-radius:8px;
            font-size:15px; background:#fffdf8; transition:0.2s;
        }
        input:focus, select:focus {outline:none; border-color:#c8102e; background:white;}

        .form-box {
            background:#fffbf5; border-radius:12px; padding:18px; 
            border:1px solid #e8d5b7; margin:15px 0;
        }
        h3 {
            color:#333; margin-bottom:12px; border-bottom:2px solid #f1e7d0; 
            padding-bottom:6px; font-size:17px;
        }
        h4 {margin:12px 0 6px; font-size:15px; color:#444;}
        .menu-item {
            padding:12px; margin:8px 0; background:#fffdf8; border-radius:8px;
            border-left:4px solid #c8102e; transition:0.2s;
        }
        .menu-item:hover {background:#fff3cd; border-left-color:#ffb300;}
        .hubung-item {display:flex; gap:8px; margin:8px 0;}
        
        button {
            padding:12px; border:none; border-radius:8px; font-weight:bold; cursor:pointer; transition:0.2s;
        }
        .tombol-daftar {
            width:100%; padding:14px;
            background:linear-gradient(135deg, #c8102e, #a00020);
            color:white; font-size:17px; margin-top:10px;
            box-shadow:0 4px 15px rgba(200,16,46,0.3);
        }
        .tombol-daftar:hover {transform:translateY(-2px);}
        .tombol-kembali {
            background:transparent; border:2px solid #888; color:#555;
            margin-top:10px; box-shadow:none; background:white;
        }

        .btn-kecil {flex:1; padding:10px; font-size:14px; margin:0;}
        .btn-kecil-putih {background:white; color:#333; border:1px solid #ddd;}
        .btn-kecil-putih:hover {background:#f1f1f1;}
        .btn-bayar {background:#d63384; display:none; width:100%; margin-top:10px; color:white;}
        .btn-peta {background:#17a2b8; color:white; width:100%; margin-top:10px;}
        .btn-peta:hover {background:#138496;}
        .btn-lapor {background:#ffc107; color:#000; width:100%; margin-top:8px;}
        .btn-lapor:hover {background:#e0a800;}
        .btn-batal {background:#6c757d; color:white; width:100%; margin-top:8px;}
        .btn-batal:hover {background:#5a6268;}
        .btn-telpon {background:#28a745; color:white;}
        .btn-telpon:hover {background:#218838;}
        .btn-wa {background:#25d366; color:white;}
        .btn-wa:hover {background:#1da851;}

        hr {margin:15px 0; border:none; border-top:1px solid #f1e7d0;}
        .isi-aturan {font-size:14px; line-height:1.7; color:#444;}
        .isi-aturan ul {margin:8px 0 0 20px;}
        .isi-aturan li {margin-bottom:4px;}

        /* === MODAL POP UP === */
        .modal {
            display:none; position:fixed; top:0; left:0; width:100%; height:100%;
            background:rgba(0,0,0,0.5); padding:20px; overflow-y:auto; z-index:100;
        }
        .modal-kotak {
            background:white; border-radius:12px; padding:20px; max-width:500px; margin:5% auto;
            border:3px solid #ffb300;
        }
        .tutup {text-align:right; font-size:22px; cursor:pointer; color:#888;}

        /* === CATATAN KHAS === */
        .catatan-tegal {
            margin-top:18px; padding:12px; background:#fff9e6; border-radius:8px;
            border-left:4px solid #ffb300; font-size:13px; line-height:1.6;
            color:#664400;
        }
    </style>
</head>
<body>

    <!-- === HIASAN LATAR === -->
    <div class="hiasan-atas"></div>
    <div class="hiasan-bawah"></div>
    <div class="garis-pabrik"></div>
    <div class="asap-pabrik">💨</div>
    <div class="awan-jepang">☁️</div>

    <!-- === KOTAK UTAMA === -->
    <div class="kotak-utama">
        <div class="header-tema">
            <div class="logo-tegal">🏯🍵🏭</div>
            <h1 class="judul-utama">KULINER NUSANTARA TEGAL</h1>
            <p class="sub-judul">Kota Seribu Buruh Pabrik & Khas Teh Poci</p>
            <div class="slogan">✨ Kelezatan Khas Kaki Lima Hingga Resto ✨</div>
        </div>

        <div class="ikon-khas">
            <div><div>🍶</div><div class="label-ikon">Teh Poci</div></div>
            <div><div>🏭</div><div class="label-ikon">Buruh Pabrik</div></div>
            <div><div>⛩️</div><div class="label-ikon">Nuansa Jepang</div></div>
            <div><div>🥘</div><div class="label-ikon">Kuliner Khas</div></div>
        </div>

        <!-- === INFO RINGKAS === -->
        <div class="info-ringkas">
            <div class="kotak-info">
                <div class="label">💳 Saldo Tersedia</div>
                <div class="angka" id="saldo">Rp 0</div>
            </div>
            <div class="kotak-info">
                <div class="label">📦 Total Pesanan</div>
                <div class="angka" id="jumlah-pesanan">0</div>
            </div>
        </div>

        <div class="pemisah">
            <span class="garis"></span>
            <span>Silakan Pilih Daftar Sebagai</span>
            <span class="garis"></span>
        </div>

        <!-- === PILIHAN PERAN === -->
        <div class="pilihan-peran" id="pilih-peran">
            <div class="kotak-peran" onclick="pilihPeran(this, 'pembeli')">
                <div class="ikon-peran">🛒</div>
                <div class="teks-peran">
                    <h4>Pembeli / Warga</h4>
                    <p>Nikmati kuliner khas Tegal & teh poci segar</p>
                </div>
            </div>

            <div class="kotak-peran" onclick="pilihPeran(this, 'pedagang')">
                <div class="ikon-peran">🏪</div>
                <div class="teks-peran">
                    <h4>Pedagang Kuliner</h4>
                    <p>Daftarkan warung, bakso, nasi ponggol, atau teh poci</p>
                </div>
            </div>

            <div class="kotak-peran" onclick="pilihPeran(this, 'pengantar')">
                <div class="ikon-peran">🛵</div>
                <div class="teks-peran">
                    <h4>Tenaga Pengantar</h4>
                    <p>Bantu warga seribu pabrik dapatkan makanan cepat</p>
                </div>
            </div>
        </div>

        <!-- === FORM ISIAN === -->
        <div id="form-isian" style="display:none;">
            <div class="pemisah">
                <span class="garis"></span>
                <span>Formulir Pendaftaran</span>
                <span class="garis"></span>
            </div>

            <div class="form-grup">
                <label>Nama Lengkap :</label>
                <input type="text" placeholder="Contoh: Budi Santoso">
            </div>

            <div class="form-grup">
                <label>No. WhatsApp / HP :</label>
                <input type="tel" placeholder="Contoh: 0882-xxxx-xxxx">
            </div>

            <div class="form-grup">
                <label>Alamat Sekitar Tegal :</label>
                <input type="text" placeholder="Contoh: Slawi, Adiwerna, atau dekat kawasan pabrik">
            </div>

            <div class="form-grup">
                <label>Kesan tentang Kota Tegal :</label>
                <select>
                    <option>Kota yang ramah & pekerja keras</option>
                    <option>Surga kuliner murah & enak</option>
                    <option>Kenikmatan Teh Poci yang tiada duanya</option>
                    <option>Kawasan pabrik yang maju</option>
                </select>
            </div>

            <button class="tombol-daftar">✅ DAFTARKAN SEKARANG</button>
            <button class="tombol-daftar tombol-kembali" onclick="kembaliPilih()">← Kembali Pilih Peran</button>
        </div>

        <!-- === METODE PEMBAYARAN === -->
        <div class="form-box">
            <h3>💳 Metode Pembayaran Tersedia</h3>
            <p class="keterangan">Sesuai standar Bank Indonesia:</p>

            <div class="menu-item">
                <label><input type="radio" name="metodeBayar" value="DANA" onclick="tampilTombolBayar()"> 💸 DANA</label>
            </div>
            <div class="menu-item">
                <label><input type="radio" name="metodeBayar" value="SHOPEEPAY" onclick="tampilTombolBayar()"> 🛒 ShopeePay</label>
            </div>
            <div class="menu-item">
                <label><input type="radio" name="metodeBayar" value="GOPAY" onclick="tampilTombolBayar()"> 🛵 GoPay</label>
            </div>
            <div class="menu-item">
                <label><input type="radio" name="metodeBayar" value="OVO" onclick="tampilTombolBayar()"> 💵 OVO</label>
            </div>
            <div class="menu-item">
                <label><input type="radio" name="metodeBayar" value="LINKAJA" onclick="tampilTombolBayar()"> 💳 LinkAja</label>
            </div>
            <div class="menu-item">
                <label><input type="radio" name="metodeBayar" value="QRIS" onclick="tampilTombolBayar()"> 📱 QRIS (Standar BI)</label>
            </div>

            <button class="btn-bayar" id="btn-bayar" onclick="mulaiProsesBayar()">✅ LANJUTKAN PEMBAYARAN</button>
        </div>

        <!-- === HUBUNGI & LAYANAN === -->
        <div class="form-box">
            <h3>📞 Hubungi Layanan</h3>
            <p class="keterangan">Aktif saat akun sudah terdaftar & pesanan berjalan:</p>

            <h4>🎧 Layanan Bantuan CS</h4>
            <div class="hubung-item">
                <button class="btn-kecil btn-telpon" onclick="window.location.href='tel:081234567890'">📞 TELEPON CS</button>
                <button class="btn-kecil btn-wa" onclick="window.location.href='https://wa.me/6281234567890?text=Halo%20Admin%2C%20saya%20butuh%20bantuan'">💬 CHAT WA CS</button>
            </div>

            <h4>🏪 Hubungi Resto</h4>
            <div class="hubung-item">
                <button class="btn-kecil btn-telpon" id="telpon-resto" onclick="hubungiResto('telpon')">📞 TELEPON RESTO</button>
                <button class="btn-kecil btn-wa" id="wa-resto" onclick="hubungiResto('wa')">💬 CHAT WA RESTO</button>
            </div>

            <h4>🛵 Hubungi Driver</h4>
            <div class="hubung-item">
                <button class="btn-kecil btn-telpon" id="telpon-driver" onclick="hubungiDriver('telpon')">📞 TELEPON DRIVER</button>
                <button class="btn-kecil btn-wa" id="wa-driver" onclick="hubungiDriver('wa')">💬 CHAT WA DRIVER</button>
            </div>

            <hr>

            <button class="btn-peta" onclick="bukaPetaLokasi()">🗺️ BUKA LOKASI GOOGLE MAPS</button>
            <button class="btn-batal">❌ BATALKAN PESANAN</button>
            <button class="btn-lapor">⚠️ LAPOR MASALAH / PELANGGARAN</button>
        </div>

        <!-- === SYARAT & KETENTUAN === -->
        <div class="form-box">
            <h3>📑 Aturan Penggunaan Aplikasi</h3>
            <p class="keterangan">Sesuai Hukum & Peraturan Republik Indonesia:</p>
            <div class="hubung-item" style="margin-top:10px;">
                <button class="btn-kecil btn-kecil-putih" onclick="bukaAturan('syarat')">📜 Syarat & Ketentuan</button>
                <button class="btn-kecil btn-kecil-putih" onclick="bukaAturan('privasi')">🔒 Kebijakan Privasi</button>
                <button class="btn-kecil btn-kecil-putih" onclick="bukaKodeEtik()">📝 Kode Etik</button>
            </div>
            <p class="keterangan" style="margin-top:10px;">
                Dengan mendaftar & menggunakan aplikasi ini, Anda dianggap menyetujui semua aturan yang berlaku
            </p>
        </div>

        <div class="catatan-tegal">
            💡 <strong>Catatan Khas Tegal:</strong> Nikmati kehangatan persaudaraan, semangat kerja keras buruh pabrik, dan kelezatan teh poci gula batu yang tak terlupakan!
        </div>
    </div>

    <!-- === MODAL SYARAT & PRIVASI === -->
    <div id="modal-syarat" class="modal">
        <div class="modal-kotak">
            <div class="tutup" onclick="tutupModal()">✕</div>
            <h3>📜 SYARAT & KETENTUAN PENGGUNAAN</h3>
            <div class="isi-aturan">
                <p><strong>1. Umum</strong></p>
                <ul>
                    <li>Aplikasi ini dikembangkan untuk program KKN Kuliner Nusantara</li>
                    <li>Berlaku hukum negara Indonesia</li>
                    <li>Pengguna wajib berusia minimal 17 tahun atau dibimbing orang tua</li>
                </ul>

                <p><strong>2. Pendaftaran Akun</strong></p>
                <ul>
                    <li>Wajib mendaftar dengan data asli & benar</li>
                    <li>Dilarang menyalahgunakan akun orang lain</li>
                    <li>Pengguna bertanggung jawab menjaga keamanan akunnya</li>
                </ul>

                <p><strong>3. Transaksi & Pembayaran</strong></p>
                <ul>
                    <li>Pembayaran melalui mitra resmi berizin Bank Indonesia (Xendit)</li>
                    <li>Harga & biaya pengiriman sesuai ketentuan berlaku</li>
                    <li>Pesanan dapat dibatalkan sesuai aturan yang berlaku</li>
                </ul>

                <p><strong>4. Kewajiban Pengguna</strong></p>
                <ul>
                    <li>Dilarang berbuat hal yang melanggar hukum, kesusilaan, atau merugikan orang lain</li>
                    <li>Dilarang mengancam, menghina, atau meminta biaya tidak wajar</li>
                    <li>Melaporkan jika menemukan indikasi penipuan atau pelanggaran</li>
                </ul>

                <p><strong>5. Layanan & Penyelesaian Masalah</strong></p>
                <ul>
                    <li>Tersedia layanan bantuan CS setiap hari jam kerja</li>
                    <li>Laporan pelanggaran akan ditindaklanjuti paling lambat 3 hari kerja</li>
                </ul>
            </div>
        </div>
    </div>

    <div id="modal-privasi" class="modal">
        <div class="modal-kotak">
            <div class="tutup" onclick="tutupModal()">✕</div>
            <h3>🔒 KEBIJAKAN PRIVASI DATA</h3>
            <div class="isi-aturan">
                <p>Kami sangat menjaga keamanan data pribadi Anda sesuai <strong>Perlindungan Data Pribadi Indonesia</strong>:</p>

                <p><strong>1. Data yang Kami Simpan</strong></p>
                <ul>
                    <li>Nama lengkap, nomor HP, alamat, & data pendaftaran lain yang Anda berikan</li>
                    <li>Riwayat pesanan, transaksi pembayaran, & data lokasi untuk keperluan pengiriman</li>
                </ul>

                <p><strong>2. Cara Kami Menggunakan Data</strong></p>
                <ul>
                    <li>Hanya untuk keperluan operasional aplikasi: pemesanan, pengiriman, pembayaran, & layanan bantuan</li>
                    <li>Tidak dijual, disebarluaskan, atau diberikan kepada pihak ketiga tanpa izin tertulis Anda</li>
                    <li>Dapat diberikan jika ada perintah sah dari penegak hukum sesuai undang-undang</li>
                </ul>

                <p><strong>3. Keamanan Penyimpanan</strong></p>
                <ul>
                    <li>Data disimpan di sistem berstandar keamanan tinggi (Firebase)</li>
                    <li>Dilindungi sistem enkripsi agar tidak diakses orang yang tidak berhak</li>
                </ul>

                <p><strong>4. Hak Pengguna</strong></p>
                <ul>
                    <li>Anda berhak melihat, memperbaiki, atau meminta penghapusan data pribadi Anda</li>
                    <li>Hubungi CS kami untuk permintaan terkait data pribadi</li>
                </ul>

                <p><strong>5. Kontak Pengelola</strong></p>
                <p>Untuk hal privasi data: Hubungi Admin melalui fitur layanan bantuan</p>
            </div>
        </div>
    </div>

    <!-- === LOGIKA PROGRAM === -->
    <script>
        const firebaseConfig = {
          apiKey: "AIzaSyA9lMH2uHFtuNsLinSZN-r2xxxxxx",
          authDomain: "kkn-kuliner-khas-nusantara.firebaseapp.com",
          databaseURL: "https://kkn-kuliner-khas-nusantara-default-rtdb.firebaseio.com",
          projectId: "kkn-kuliner-khas-nusantara",
          storageBucket: "kkn-kuliner-khas-nusantara.appspot.com",
          messagingSenderId: "121728270775",
          appId: "1:121728270775:web:3a3f8b5ad73xxxxxx"
        };
        firebase.initializeApp(firebaseConfig);
        const db = firebase.database();

        let peranTerpilih = "";
        let metodeTerpilih = "";
        let noResto = "";
        let noDriver = "";

        // === FUNGSI PILIHAN PERAN ===
        function pilihPeran(elemen, peran) {
            document.querySelectorAll('.kotak-peran').forEach(e => e.classList.remove('terpilih'));
            elemen.classList.add('terpilih');
            peranTerpilih = peran;
            
            setTimeout(() => {
                document.getElementById('pilih-peran').style.display = 'none';
                document.getElementById('form-isian').style.display = 'block';
            }, 300);
        }

        function kembaliPilih() {
            document.getElementById('form-isian').style.display = 'none';
            document.getElementById('pilih-peran').style.display = 'grid';
            document.querySelectorAll('.kotak-peran').forEach(e => e.classList.remove('terpilih'));
            peranTerpilih = "";
        }

        // === FUNGSI MODAL ===
        function bukaAturan(jenis){
            if(jenis === 'syarat') document.getElementById('modal-syarat').style.display = 'block';
            else document.getElementById('modal-privasi').style.display = 'block';
        }
        function tutupModal(){
            document.getElementById('modal-syarat').style.display = 'none';
            document.getElementById('modal-privasi').style.display = 'none';
        }

        // === FUNGSI DATA DATABASE ===
        db.ref("DataPengguna").on("value", snap => {
            if(snap.exists()){
                const data = snap.val();
                document.getElementById('saldo').textContent = "Rp " + (data.saldo || 0).toLocaleString('id-ID');
            }
        });

        db.ref("PesananMasuk").on("value", snap => {
            document.getElementById('jumlah-pesanan').textContent = snap.numChildren();
        });

        db.ref("DataResto").on("value", s => {
            const data = s.val();
            noResto = data?.no_telp_resto || "0812xxxx";
        });
        db.ref("DataDriver").on("value", s => {
            const data = s.val();
            noDriver = data?.no_telp_driver || "0813xxxx";
        });

        // === FUNGSI HUBUNGI ===
        function hubungiResto(jenis){
            if(!noResto) return alert("⚠️ Nomor Resto belum tersedia!");
            if(jenis === 'telpon') window.location.href = `tel:${noResto}`;
            else {
                const noWa = noResto.replace(/^0/, '62');
                window.location.href = `https://wa.me/${noWa}?text=Halo%20Resto%2C%20saya%20mau%20tanya%20pesanan`;
            }
        }

        function hubungiDriver(jenis){
            if(!noDriver) return alert("⚠️ Belum ada driver yang mengambil pesanan!");
            if(jenis === 'telpon') window.location.href = `tel:${noDriver}`;
            else {
                const noWa = noDriver.replace(/^0/, '62');
                window.location.href = `https://wa.me/${noWa}?text=Halo%20Pak%20Driver%2C%20dimana%20posisinya%20sekarang%3F`;
            }
        }

        // === FUNGSI PETA ===
        function bukaPetaLokasi(){
            const lokasi = prompt("Masukkan alamat atau nama tempat:");
            if(!lokasi) return;
            window.open(`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(lokasi)}`, "_blank");
        }

        // === FUNGSI PEMBAYARAN ===
        function tampilTombolBayar(){
            metodeTerpilih = document.querySelector('input[name="metodeBayar"]:checked').value;
            document.getElementById('btn-bayar').style.display = 'block';
        }

        function mulaiProsesBayar(){
            if(!metodeTerpilih) return alert("⚠️ Pilih dulu metodenya!");
            const nominal = 0;
            const idTransaksi = "transaksi-" + Date.now();

            if(metodeTerpilih === "QRIS"){
                Xendit.QRCode.create({type: "QRIS", amount: nominal, external_id: idTransaksi}, (err, res) => {
                    if(res){ alert("✅ QRIS Dibuat! Silakan scan."); simpanKeDb(idTransaksi, metodeTerpilih, nominal); }
                    else alert("❌ Gagal: " + err.message);
                });
            } else {
                Xendit.EWallet.createPayment({type: metodeTerpilih, amount: nominal, external_id: idTransaksi}, (err, res) => {
                    if(res){ alert(`✅ Buka aplikasi ${metodeTerpilih} untuk bayar!`); simpanKeDb(idTransaksi, metodeTerpilih, nominal); }
                    else alert("❌ Gagal: " + err.message);
                });
            }
        }

        function simpanKeDb(id, metode, total){
            db.ref("RiwayatPembayaran/" + id).set({
                metode_pembayaran: metode, total_bayar: total,
                status: "Menunggu Pembayaran",
                waktu: firebase.database.ServerValue.TIMESTAMP
            });
        }

        // === ATURAN PEMBATALAN & SANKSI ===
        const ATURAN = {
          batasBatalHarian: 2,
          durasiSuspendHarian: 24,
          batasBatalBulanan: 15,
          sanksiPermanent: true
        };

        function cekBatasPembatalan(idDriver) {
          const hariIni = new Date().toISOString().slice(0,10);
          db.ref("DataDriver/" + idDriver).once("value", snap => {
            const data = snap.val() || {};
            
            const batalHariIni = data.batalHariIni || 0;
            const batalBulanIni = data.batalBulanIni || 0;
            const tglTerakhirBatal = data.tglTerakhirBatal || "";
            const statusBlokir = data.statusBlokir || "Aktif";

            if(statusBlokir !== "Aktif") {
              alert(`AKUN DIBLOKIR!\nAlasan: ${data.alasanBlokir}\nSampai: ${data.sampaiBlokir || "PERMANEN"}`);
              return;
            }

            if(tglTerakhirBatal !== hariIni) {
              db.ref("DataDriver/" + idDriver).update({
                batalHariIni: 0,
                tglTerakhirBatal: hariIni
              });
            }

            const jumlahBatalBaru = batalHariIni + 1;
            if(jumlahBatalBaru > ATURAN.batasBatalHarian) {
              const waktuSelesai = new Date(Date.now() + (ATURAN.durasiSuspendHarian * 3600000));
              db.ref("DataDriver/" + idDriver).update({
                statusBlokir: "Suspend Sementara",
                alasanBlokir: "Melebihi batas 2x pembatalan sehari",
                sampaiBlokir: waktuSelesai.toLocaleString('id-ID')
              });
              alert(`⚠️ PERINGATAN! Anda membatalkan pesanan ke-${jumlahBatalBaru} hari ini.\nAKUN DIBLOKIR SELAMA 24 JAM!`);
              return;
            }

            const jumlahBatalBulanBaru = batalBulanIni + 1;
            if(jumlahBatalBulanBaru >= ATURAN.batasBatalBulanan) {
              db.ref("DataDriver/" + idDriver).update({
                statusBlokir: "BLOKIR PERMANEN",
                alasanBlokir: `Mencapai ${jumlahBatalBulanBaru} kali pembatalan dalam 1 bulan`,
                sampaiBlokir: "SELAMANYA"
              });
              alert(`❌ SANKSI TERBERAT!\nAnda sudah membatalkan ${jumlahBatalBulanBaru} kali dalam sebulan.\nAKUN DIBLOKIR PERMANEN!`);
              return;
            }

            db.ref("DataDriver/" + idDriver).update({
              batalHariIni: jumlahBatalBaru,
              batalBulanIni: jumlahBatalBulanBaru,
              tglTerakhirBatal: hariIni
            });

            alert(`Pesanan berhasil dibatalkan.\nSisa batas hari ini: ${ATURAN.batasBatalHarian - jumlahBatalBaru} kali\nSisa batas bulan ini: ${ATURAN.batasBatalBulanan - jumlahBatalBulanBaru} kali`);
          });
        }

        // === KODE ETIK & HUKUM ===
        const KODE_ETIK = `
📜 KODE ETIK DAN KETENTUAN HUKUM
1. Bertindak jujur, sopan, dan bertanggung jawab
2. Dilarang meminta biaya tambahan di luar ketentuan aplikasi
3. Dilarang memalsukan data pesanan atau lokasi
4. Wajib mematuhi peraturan lalu lintas Republik Indonesia
5. Dilarang melakukan tindakan yang melanggar hukum, kekerasan, atau penipuan
6. Menjaga kerahasiaan data pengguna aplikasi

⚠️ PELANGGARAN:
- Pelanggaran ringan: Peringatan tertulis
- Pelanggaran sedang: Blokir sementara 7-30 hari
- Pelanggaran berat/hukum: Blokir PERMANEN & dilaporkan ke pihak berwajib
        `;

        function bukaKodeEtik() {
          alert(KODE_ETIK);
        }   
    </script>

</body>
</html>
