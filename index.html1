<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KKN Kuliner Nusantara - Driver</title>
    <script src="https://cdn.xendit.co/xenpayment.js"></script>
    <style>
        * {margin:0; padding:0; box-sizing:border-box; font-family:Arial, sans-serif;}
        body {background:#e3f2fd; padding:0; padding-top:50px; padding-bottom:60px;}

        /* === HEADER ATAS === */
        .header-bar {
            position:fixed; top:0; left:0; right:0; background:#1976d2; color:white;
            padding:12px 15px; display:flex; align-items:center; justify-content:space-between;
            z-index:999;
        }
        .header-judul {font-size:18px; font-weight:bold;}
        .icon-pengaturan {font-size:20px; cursor:pointer;}
        
        /* === PETA & TOMBOL STATUS === */
        .peta-container {
            width:100%; height:45vh; background:#e3f2fd;
            position:relative; border-bottom-left-radius:20px; border-bottom-right-radius:20px;
        }
        .tombol-daya {
            position:absolute; left:30px; top:50%; transform:translateY(-50%);
            width:60px; height:60px; border-radius:50%; background:#28a745;
            display:flex; align-items:center; justify-content:center; color:white;
            font-size:28px; font-weight:bold; cursor:pointer; box-shadow:0 3px 10px rgba(0,0,0,0.2);
            transition:0.3s; z-index:10;
        }
        .tombol-daya.off {background:#dc3545;}
        .tombol-daya:hover {transform:translateY(-52%);}

        .indikator-posisi {
            position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
            width:50px; height:50px; background:#0277bd; border-radius:50%;
            border:3px solid white; box-shadow:0 0 0 3px rgba(2,119,189,0.3);
        }
        .tombol-samping {
            position:absolute; right:15px; display:flex; flex-direction:column; gap:10px;
            top:50%; transform:translateY(-50%);
        }
        .btn-samping {
            width:45px; height:45px; border-radius:50%; background:white;
            display:flex; align-items:center; justify-content:center; font-size:20px;
            box-shadow:0 2px 8px rgba(0,0,0,0.1); cursor:pointer;
        }

        /* === STATUS KERJA === */
        .status-bawah {
            padding:20px; background:white; margin:-20px 15px 15px; border-radius:12px;
            box-shadow:0 -3px 10px rgba(0,0,0,0.05); position:relative; z-index:10;
        }
        .status-teks {
            font-size:20px; font-weight:bold; display:flex; align-items:center; gap:12px;
        }
        .titik-merah {width:14px; height:14px; border-radius:50%; background:#dc3545;}
        .titik-hijau {background:#28a745;}

        /* === KOTAK RINGKASAN === */
        .ringkasan-grid {
            display:grid; grid-template-columns:1fr 1fr; gap:12px; margin:15px;
        }
        .kotak-ringkas {
            background:white; padding:15px; border-radius:10px; text-align:center;
            box-shadow:0 2px 6px rgba(0,0,0,0.05);
        }
        .angka-besar {font-size:22px; font-weight:bold; color:#28a745; margin-bottom:4px;}
        .label-kecil {font-size:13px; color:#666;}

        /* === TOMBOL PINTAS === */
        .pintas-container {padding:15px; background:white; margin:15px; border-radius:12px; display:none;}
        .pintas-judul {font-size:17px; font-weight:bold; margin-bottom:15px; color:#333;}
        .grid-pintas {
            display:grid; grid-template-columns:repeat(4, 1fr); gap:15px; text-align:center;
        }
        .item-pintas {cursor:pointer; transition:0.2s; padding:8px; border-radius:8px;}
        .item-pintas:hover {background:#f5f5f5;}
        .ikon-pintas {
            width:50px; height:50px; border-radius:50%; background:#e0f2f1;
            display:flex; align-items:center; justify-content:center; margin:0 auto 6px;
            font-size:22px; color:#00897b;
        }
        .item-pintas p {font-size:13px; color:#444;}

        /* === MODAL UMUM === */
        .modal {
            display:none; position:fixed; top:0; left:0; width:100%; height:100%;
            background:rgba(0,0,0,0.5); padding:20px; z-index:1000; overflow-y:auto;
        }
        .modal-kotak {
            background:white; border-radius:12px; padding:20px; max-width:420px; margin:5% auto;
        }
        .tutup {text-align:right; font-size:22px; cursor:pointer; color:#888; margin-bottom:10px;}
        .layanan-item {
            padding:14px; border-bottom:1px solid #f1f1f1; cursor:pointer; display:flex; align-items:center; gap:12px;
        }
        .layanan-item:hover {background:#f8f9fa;}
        .aturan-box {
            background:#fafafa; border:1px solid #e0e0e0; border-radius:8px; padding:12px;
            margin:10px 0; font-size:13px; line-height:1.6;
        }
        .btn-modal {width:100%; padding:14px; background:#28a745; color:white; border:none; border-radius:8px; font-weight:bold; margin-top:10px; cursor:pointer;}
        .btn-modal.biru {background:#1976d2;}
        .btn-modal.kuning {background:#fbc02d; color:#333;}

        /* === PROFIL MENU === */
        .profil-menu {padding:10px 0;}
        .profil-item {
            padding:14px; display:flex; align-items:center; gap:12px; border-bottom:1px solid #f1f1f1;
            cursor:pointer;
        }
        .profil-item:hover {background:#f8f9fa;}
        .ikon-profil {font-size:24px; width:40px; text-align:center;}

        /* === FITUR CHAT === */
        .tab-chat {
            flex:1; padding:8px; border:none; border-radius:8px; background:#f0f0f0; cursor:pointer; font-weight:500;
        }
        .tab-chat.aktif {background:#28a745; color:white;}
        .area-chat {
            flex:1; overflow-y:auto; padding:10px 0; display:flex; flex-direction:column; gap:10px; min-height:200px;
        }
        .pesan {
            max-width:80%; padding:10px 14px; border-radius:18px; font-size:14px; line-height:1.5; position:relative;
        }
        .pesan.terima {
            background:#f1f1f1; color:#333; align-self:flex-start; border-bottom-left-radius:4px;
        }
        .pesan.kirim {
            background:#e3f2fd; color:#1a237e; align-self:flex-end; border-bottom-right-radius:4px;
        }
        .waktu-pesan {font-size:11px; color:#888; margin-top:4px; text-align:right;}

        /* === PESANAN MASUK === */
        .pesanan-masuk {
            position:fixed; bottom:70px; left:0; right:0; background:white;
            border-top-left-radius:20px; border-top-right-radius:20px; padding:20px;
            box-shadow:0 -5px 15px rgba(0,0,0,0.15); display:none; z-index:99;
            animation: munculNaik 0.5s ease-out;
        }
        @keyframes munculNaik {from{transform:translateY(100%);} to{transform:translateY(0);}}
        .pesanan-header {display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;}
        .nama-pemesan {font-size:20px; font-weight:bold;}
        .alamat-pesan {font-size:16px; color:#333; margin:8px 0; line-height:1.5;}
        .bayaran {font-size:22px; font-weight:bold; color:#28a745; margin:8px 0;}
        .tombol-pesanan {display:flex; gap:10px; margin-top:15px;}
        .btn-terima {flex:1; padding:15px; background:#28a745; color:white; border:none; border-radius:10px; font-size:17px; font-weight:bold; cursor:pointer;}
        .btn-tolak {width:60px; height:60px; border-radius:50%; background:#dc3545; color:white; border:none; font-size:22px; cursor:pointer;}

        /* === DETAIL PESANAN === */
        .detail-pesanan {padding:20px; display:none;}
        .detail-header {display:flex; align-items:center; gap:12px; margin-bottom:20px;}
        .btn-kembali {font-size:24px; cursor:pointer; color:#555;}
        .tombol-aksi {display:flex; gap:12px; margin:20px 0; align-items:center;}
        .btn-telepon, .btn-chat {width:45px; height:45px; border-radius:50%; background:#e0e0e0; display:flex; align-items:center; justify-content:center; font-size:20px; cursor:pointer;}
        .btn-diantarkan {width:100%; padding:16px; background:#28a745; color:white; border:none; border-radius:12px; font-size:18px; font-weight:bold; cursor:pointer; margin-top:15px;}

        /* === RIWAYAT === */
        .item-riwayat {
            padding:12px; border-bottom:1px solid #f1f1f1; display:flex; justify-content:space-between; align-items:center;
        }
        .tanggal {font-size:13px; color:#888;}
        .nominal-masuk {color:#28a745; font-weight:bold;}
        .nominal-keluar {color:#dc3545; font-weight:bold;}

        /* === MENU RESTORAN === */
        .item-menu {
            padding:12px; border-bottom:1px solid #f1f1f1; display:flex; gap:12px; align-items:center;
        }
        .foto-menu {width:60px; height:60px; background:#e0f2f1; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:28px;}
        .info-menu {flex:1;}
        .nama-menu {font-weight:bold;}
        .harga-menu {color:#28a745; font-weight:bold; margin-top:2px;}
        .aksi-menu {display:flex; gap:8px;}
        .btn-aksi-kecil {padding:6px 10px; border-radius:6px; border:none; font-size:13px; cursor:pointer;}

        /* === NAVIGASI BAWAH === */
        .nav-bawah {
            position:fixed; bottom:0; left:0; right:0; background:white; border-top:1px solid #eee;
            display:flex; justify-content:space-around; padding:10px 0; z-index:50;
        }
        .nav-item {text-align:center; font-size:13px; color:#666; cursor:pointer;}
        .nav-item.aktif {color:#dc3545; font-weight:bold;}
        .nav-ikon {font-size:22px; display:block; margin-bottom:2px;}
    </style>
</head>
<body>

<!-- 🔹 HEADER ATAS -->
<div class="header-bar">
    <span class="icon-pengaturan">⚙️</span>
    <span class="header-judul">KKN Kuliner Nusantara</span>
    <span></span>
</div>

<!-- 🗺️ PETA UTAMA -->
<div class="peta-container">
    <div class="tombol-daya" id="tombol-daya" onclick="gantiStatus()">⏻</div>
    <div class="indikator-posisi"></div>
    <div class="tombol-samping">
        <div class="btn-samping">🌧️</div>
        <div class="btn-samping">⬜</div>
        <div class="btn-samping" onclick="bukaPintas()">⋯</div>
    </div>
</div>

<!-- 📊 STATUS KERJA -->
<div class="status-bawah">
    <div class="status-teks">
        <span class="titik-merah" id="titik-status"></span>
        <span id="teks-status">Anda sedang tidak aktif</span>
    </div>
</div>

<!-- 📋 RINGKASAN PENDAPATAN & TABUNGAN -->
<div class="ringkasan-grid">
    <div class="kotak-ringkas" onclick="bukaModal('pendapatan')">
        <div class="angka-besar">Rp 87.500</div>
        <div class="label-kecil">💵 Pendapatan Hari Ini</div>
    </div>
    <div class="kotak-ringkas" onclick="bukaModal('tabungan')">
        <div class="angka-besar">Rp 1.850.000</div>
        <div class="label-kecil">💰 Total Tabungan</div>
    </div>
</div>

<!-- ⚡ TOMBOL PINTAS -->
<div class="pintas-container" id="kotak-pintas">
    <div class="pintas-judul">Tombol Pintas</div>
    <div class="grid-pintas">
        <div class="item-pintas" onclick="bukaModal('profil')">
            <div class="ikon-pintas">👤</div>
            <p>Profil</p>
        </div>
        <div class="item-pintas" onclick="bukaModal('layanan')">
            <div class="ikon-pintas">🛵</div>
            <p>Layanan</p>
        </div>
        <div class="item-pintas" onclick="bukaModal('pendapatan')">
            <div class="ikon-pintas">💵</div>
            <p>Pendapatan</p>
        </div>
        <div class="item-pintas" onclick="bukaModal('tabungan')">
            <div class="ikon-pintas">💰</div>
            <p>Tabungan</p>
        </div>
    </div>
</div>

<!-- 👤 MODAL PILIH PROFIL -->
<div class="modal" id="modal-profil">
    <div class="modal-kotak">
        <div class="tutup" onclick="tutupModal()">✕</div>
        <h3>Pilih Profil</h3>
        <div class="profil-menu">
            <div class="profil-item" onclick="bukaDetailProfil('driver')">
                <span class="ikon-profil">🚗</span>
                <div>
                    <strong>Profil Driver</strong>
                    <p style="font-size:13px; color:#666;">Data diri & kendaraan</p>
                </div>
            </div>
            <div class="profil-item" onclick="bukaDetailProfil('restoran')">
                <span class="ikon-profil">🏪</span>
                <div>
                    <strong>Profil Restoran</strong>
                    <p style="font-size:13px; color:#666;">Kelola menu & operasional</p>
                </div>
            </div>
            <div class="profil-item" onclick="bukaDetailProfil('pelanggan')">
                <span class="ikon-profil">🧑‍🤝‍🧑</span>
                <div>
                    <strong>Profil Pelanggan</strong>
                    <p style="font-size:13px; color:#666;">Daftar pelanggan tetap</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 💵 MODAL PENDAPATAN DRIVER -->
<div class="modal" id="modal-pendapatan">
    <div class="modal-kotak">
        <div class="tutup" onclick="tutupModal()">✕</div>
        <h3>💵 Pendapatan Driver</h3>

        <div style="background:#f8f9fa; padding:15px; border-radius:8px; margin:15px 0;">
            <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
                <span>Hari Ini</span>
                <strong style="color:#28a745;">Rp 87.500</strong>
            </div>
            <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
                <span>Bulan Ini</span>
                <strong style="color:#28a745;">Rp 2.450.000</strong>
            </div>
            <div style="display:flex; justify-content:space-between;">
                <span>Total Keseluruhan</span>
                <strong style="color:#1976d2;">Rp 18.720.000</strong>
            </div>
        </div>

        <h4 style="margin-bottom:10px;">📝 Rincian Hari Ini</h4>
        <div class="item-riwayat">
            <div>
                <div>Antar Nasi Goreng</div>
                <div class="tanggal">Pukul 12:30</div>
            </div>
            <div class="nominal-masuk">+ Rp 12.500</div>
        </div>
        <div class="item-riwayat">
            <div>
                <div>Antar Paket Restoran</div>
                <div class="tanggal">Pukul 14:15</div>
            </div>
            <div class="nominal-masuk">+ Rp 18.000</div>
        </div>
        <div class="item-riwayat">
            <div>
                <div>Potongan Tabungan 5%</div>
                <div class="tanggal">Otomatis</div>
            </div>
            <div class="nominal-keluar">- Rp 625</div>
        </div>

        <button class="btn-modal" style="margin-top:15px;">✅ Tarik Saldo ke Rekening</button>
    </div>
</div>

<!-- 💰 MODAL TABUNGAN DRIVER -->
<div class="modal" id="modal-tabungan">
    <div class="modal-kotak">
        <div class="tutup" onclick="tutupModal()">✕</div>
        <h3>💰 Tabungan Pengemudi</h3>

        <div style="text-align:center; padding:20px 0;">
            <div style="font-size:32px; font-weight:bold; color:#28a745;">Rp 1.850.000</div>
            <p style="color:#666; margin-top:5px;">Total Tabungan Terkumpul</p>
        </div>

        <div class="aturan-box">
            <strong>📌 Aturan Tabungan:</strong><br>
            ✅ Dipotong otomatis <strong>5%</strong> dari setiap pendapatan bersih<br>
            ✅ Aman & tercatat sistem<br>
            ✅ Bisa ditarik kapan saja minimal Rp 100.000<br>
            ✅ Bebas biaya administrasi penarikan
        </div>

        <h4 style="margin:15px 0 10px;">📊 Riwayat Tabungan</h4>
        <div class="item-riwayat">
            <div>
                <div>Setoran Otomatis</div>
                <div class="tanggal">30 Jun 2026</div>
            </div>
            <div class="nominal-masuk">+ Rp 625</div>
        </div>
        <div class="item-riwayat">
            <div>
                <div>Penarikan ke Rekening</div>
                <div class="tanggal">25 Jun 2026</div>
            </div>
            <div class="nominal-keluar">- Rp 500.000</div>
        </div>

        <button class="btn-modal kuning" style="margin-top:10px;">💳 Ajukan Penarikan</button>
    </div>
</div>

<!-- 🏪 MODAL PROFIL RESTORAN & KELOLA MENU -->
<div class="modal" id="modal-restoran">
    <div class="modal-kotak">
        <div class="tutup" onclick="tutupModal()">✕</div>
        <h3>🏪 Kelola Restoran</h3>

        <div style="display:flex; gap:12px; align-items:center; margin-bottom:15px;">
            <div style="width:70px; height:70px; background:#e0f2f1; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:32px;">🏪</div>
            <div>
                <strong style="font-size:18px;">Restoran Sari Rasa</strong><br>
                <span style="color:#666;">Makanan Tradisional Indonesia</span><br>
                <span style="color:#28a745; font-size:13px;">● Buka Sekarang</span>
            </div>
        </div>

        <div style="display:flex; gap:8px; margin-bottom:15px;">
            <button class="btn-modal biru" style="flex:1; padding:10px;" onclick="bukaModal('daftar-menu')">📋 Daftar Menu</button>
            <button class="btn-modal" style="flex:1; padding:10px;" onclick="bukaModal('kelola-menu')">➕ Tambah Menu</button>
        </div>

        <div class="layanan-item" onclick="alert('Buka pengaturan jam operasional')">⏰ Jam Buka/Tutup</div>
        <div class="layanan-item" onclick="alert('Buka riwayat pesanan restoran')">📩 Riwayat Pesanan</div>
        <div class="layanan-item" onclick="alert('Buka laporan pendapatan restoran')">📊 Laporan Pendapatan</div>
    </div>
</div>

<!-- 📋 MODAL DAFTAR MENU RESTORAN -->
<div class="modal" id="modal-daftar-menu">
    <div class="modal-kotak">
        <div class="tutup" onclick="tutupModal()">✕</div>
        <h3>📋 Daftar Menu Restoran</h3>

        <div class="item-menu">
            <div class="foto-menu">🍜</div>
            <div class="info-menu">
                <div class="nama-menu">Nasi Goreng Spesial</div>
                <div class="harga-menu">Rp 18.000</div>
            </div>
            <div class="aksi-menu">
                <button class="btn-aksi-kecil" style="background:#e3f2fd; color:#1976d2;">✏️</button>
                <button class="btn-aksi-kecil" style="background:#ffebee; color:#dc3545;">🗑️</button>
            </div>
        </div>

        <div class="item-menu">
            <div class="foto-menu">🍛</div>
            <div class="info-menu">
                <div class="nama-menu">Ayam Gulai Khas Padang</div>
                <div class="harga-menu">Rp 25.000</div>
            </div>
            <div class="aksi-menu">
                <button class="btn-aksi-kecil" style="background:#e3f2fd; color:#1976d2;">✏️</button>
                <button class="btn-aksi-kecil" style="background:#ffebee; color:#dc3545;">🗑️</button>
            </div>
        </div>

        <div class="item-menu">
            <div class="foto-menu">🥤</div>
            <div class="info-menu">
                <div class="nama-menu">Es Teh Manis</div>
                <div class="harga-menu">Rp 3.000</div>
            </div>
            <div class="aksi-menu">
                <button class="btn-aksi-kecil" style="background:#e3f2fd; color:#1976d2;">✏️</button>
                <button class="btn-aksi-kecil" style="background:#ffebee; color:#dc3545;">🗑️</button>
            </div>
        </div>

        <button class="btn-modal" style="margin-top:15px;" onclick="bukaModal('kelola-menu')">➕ Tambah Menu Baru</button>
    </div>
</div>

<!-- 📝 MODAL KELOLA TAMBAH MENU -->
<div class="modal" id="modal-kelola-menu">
    <div class="modal-kotak">
        <div class="tutup" onclick="tutupModal()">✕</div>
        <h3>➕ Tambah Menu Baru</h3>

        <div style="margin-bottom:12px;">
            <label style="font-weight:bold; display:block; margin-bottom:5px;">Nama Menu</label>
            <input type="text" placeholder="Contoh: Soto Ayam Lamongan" 
                   style="width:100%; padding:10px; border:1px solid #ddd; border-radius:8px;">
        </div>

        <div style="margin-bottom:12px;">
            <label style="font-weight:bold; display:block; margin-bottom:5px;">Foto Menu</label>
            <input type="file" accept="image/*" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:8px;">
        </div>

        <div style="margin-bottom:12px;">
            <label style="font-weight:bold; display:block; margin-bottom:5px;">Deskripsi Singkat</label>
            <textarea placeholder="Kuah bening, ayam suwir, soun, telur rebus..." rows="2"
                      style="width:100%; padding:10px; border:1px solid #ddd; border-radius:8px;"></textarea>
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:12px;">
            <div>
                <label style="font-weight:bold; display:block; margin-bottom:5px;">Harga (Rp)</label>
                <input type="number" placeholder="15000" 
                       style="width:100%; padding:10px; border:1px solid #ddd; border-radius:8px;">
            </div>
            <div>
                <label style="font-weight:bold; display:block; margin-bottom:5px;">Kategori</label>
                <select style="width:100%; padding:10px; border:1px solid #ddd; border-radius:8px;">
                    <option>Makanan Berat</option>
                    <option>Camilan</option>
                    <option>Minuman</option>
                    <option>Makanan Ringan</option>
                </select>
            </div>
        </div>

        <button class="btn-modal" onclick="simpanMenu()">✅ Simpan Menu</button>
    </div>
</div>

<!-- 🛵 MODAL LAYANAN -->
<div class="modal" id="modal-layanan">
    <div class="modal-kotak">
        <div class="tutup" onclick="tutupModal()">✕</div>
        <h3>Pilih Jenis Layanan</h3>
        <div class="layanan-item" onclick="pilihLayanan('makanan')">
            <span>🍜</span> Layanan Makanan
        </div>
        <div class="layanan-item" onclick="pilihLayanan('kurir')">
            <span>📦</span> Layanan Kurir Paket
        </div>
    </div>
</div>

<!-- 💬 MODAL CHAT -->
<div class="modal" id="modal-chat">
    <div class="modal-kotak" style="max-width:450px; max-height:85vh; display:flex; flex-direction:column;">
        <div class="tutup" onclick="tutupChat()">✕</div>
        <div style="display:flex; gap:10px; margin-bottom:10px;">
            <button class="tab-chat aktif" onclick="gantiTabChat('pelanggan')">🧑‍🤝‍🧑 Pelanggan</button>
            <button class="tab-chat" onclick="gantiTabChat('restoran')">🏪 Restoran</button>
        </div>
        <div id="judul-chat" style="font-weight:bold; font-size:16px; padding:8px 0; border-bottom:1px solid #eee;">💬 Budi Santoso</div>
        <div id="daftar-pesan" class="area-chat"></div>
        <div style="display:flex; gap:8px; margin-top:10px;">
            <input type="text" id="input-pesan" placeholder="Ketik pesan disini..." style="flex:1; padding:12px; border:1px solid #ddd; border-radius:20px; outline:none;">
            <button onclick="kirimPesan()" style="width:45px; height:45px; border-radius:50%; border:none; background:#28a745; color:white; font-size:18px; cursor:pointer;">➤</button>
        </div>
    </div>
</div>

<!-- 📦 PESANAN MASUK -->
<div class="pesanan-masuk" id="pesanan-masuk">
    <div class="pesanan-header">
        <div>
            <div class="nama-pemesan" id="nama-pemesan">BUDI SANTOSO</div>
            <div style="font-size:14px; color:#888;">07:45 PM</div>
        </div>
        <div class="bayaran" id="bayaran-pesanan">Rp 12.500 💚 Nontunai</div>
    </div>
    <div style="background:#e8f5e9; border-left:4px solid #43a047; padding:8px; border-radius:6px; margin:8px 0;">
        📍 Ambil di: <strong>Restoran Sari Rasa</strong>
    </div>
    <div class="alamat-pesan">📍 Tujuan: Jalan Merdeka No.12, Semarang</div>
    <div class="tombol-pesanan">
        <button class="btn-tolak" onclick="tolakPesanan()">✕</button>
        <button class="btn-terima" onclick="terimaPesanan()">Ambil & Antarkan</button>
    </div>
</div>

<!-- 📋 DETAIL PESANAN -->
<div class="detail-pesanan" id="detail-pesanan">
    <div class="detail-header">
        <span class="btn-kembali" onclick="kembaliKePeta()">←</span>
        <div>
            <h2>PK-7892</h2>
            <p style="color:#666;">📍 Restoran Sari Rasa</p>
        </div>
    </div>
    <div style="margin:15px 0; font-size:17px;">
        📍 Tujuan: Jalan Merdeka No.12, Semarang<br>
        <strong>Catatan:</strong> Serahkan langsung ke penerima
    </div>
    <div class="tombol-aksi">
        <div class="btn-telepon" onclick="alert('📞 Menghubungi...')">📞</div>
        <div class="btn-chat" onclick="bukaChat('pelanggan')">💬</div>
        <div class="btn-chat" onclick="bukaChat('restoran')">🏪</div>
        <div style="flex:1;"></div>
        <button class="btn-diantarkan" onclick="tandaiSampai()">✅ Paket Telah Diterima</button>
    </div>
</div>

<!-- 🧭 NAVIGASI BAWAH -->
<div class="nav-bawah">
    <div class="nav-item aktif"><span class="nav-ikon">🏠</span> Beranda</div>
    <div class="nav-item" onclick="bukaModal('pendapatan')"><span class="nav-ikon">💵</span> Pendapatan</div>
    <div class="nav-item"><span class="nav-ikon">📥</span> Kotak Masuk</div>
    <div class="nav-item" onclick="bukaModal('tabungan')"><span class="nav-ikon">💰</span> Tabungan</div>
    <div class="nav-item" onclick="bukaModal('profil')"><span class="nav-ikon">👤</span> Profil</div>
</div>

<script>
let statusAktif = false;
let layananAktif = 'makanan';
let tipeChatSekarang = 'pelanggan';

// 🔊 SUARA NOTIFIKASI KHAS
function bunyiPesanRestoran(){
    const suara = new AudioContext();
    const nada = suara.createOscillator();
    const volume = suara.createGain();
    nada.connect(volume); volume.connect(suara.destination);
    nada.type = 'sine'; volume.gain.value = 0.25;
    nada.frequency.setValueAtTime(622, suara.currentTime);
    nada.frequency.setValueAtTime(740, suara.currentTime + 0.15);
    nada.frequency.setValueAtTime(523, suara.currentTime + 0.3);
    volume.gain.exponentialRampToValueAtTime(0.01, suara.currentTime + 0.6);
    nada.start(); nada.stop(suara.currentTime + 0.6);
    if ('speechSynthesis' in window) {
        const ucap = new SpeechSynthesisUtterance();
        ucap.lang = 'id-ID'; ucap.text = "Halo! Ada pesanan baru dari dapur, silakan ambil ya!";
        ucap.rate = 1.1; ucap.pitch = 1.05; speechSynthesis.speak(ucap);
    }
}

// 🔘 TOMBOL STATUS
function gantiStatus(){
    statusAktif = !statusAktif;
    const tombol = document.getElementById('tombol-daya');
    const titik = document.getElementById('titik-status');
    const teks = document.getElementById('teks-status');

    if(statusAktif){
        tombol.classList.remove('off');
        titik.classList.remove('titik-merah'); titik.classList.add('titik-hijau');
        teks.textContent = layananAktif === 'makanan' ? "Siap Antar Makanan" : "Siap Antar Paket";
        setTimeout(()=>{bunyiPesanRestoran(); document.getElementById('pesanan-masuk').style.display='block';}, 3000);
    } else {
        tombol.classList.add('off');
        titik.classList.remove('titik-hijau'); titik.classList.add('titik-merah');
        teks.textContent = "Anda sedang tidak aktif";
        document.getElementById('pesanan-masuk').style.display = 'none';
        document.getElementById('detail-pesanan').style.display = 'none';
    }
}

// FUNGSI PROFIL
function bukaDetailProfil(jenis){
    tutupModal();
    if(jenis==='driver'){
        alert("👤 Membuka halaman Profil Driver");
    } else if(jenis==='restoran'){
        bukaModal('restoran');
    } else {
        alert("🧑‍🤝‍🧑 Membuka daftar Pelanggan");
    }
}

// FUNGSI KELOLA MENU RESTORAN
function simpanMenu(){
    alert("✅ Menu berhasil disimpan! Langsung tampil untuk pelanggan.");
    tutupModal();
}

// FUNGSI UMUM
function pilihLayanan(j){layananAktif=j; tutupModal();}
function bukaPintas(){document.getElementById('kotak-pintas').style.display = document.getElementById('kotak-pintas').style.display==='none'?'block':'none';}
function bukaModal(j){document.getElementById('kotak-pintas').style.display='none'; document.getElementById(`modal-${j}`).style.display='block';}
function tutupModal(){document.querySelectorAll('.modal').forEach(m=>m.style.display='none');}
function terimaPesanan(){document.getElementById('pesanan-masuk').style.display='none'; document.getElementById('detail-pesanan').style.display='block';}
function tolakPesanan(){document.getElementById('pesanan-masuk').style.display='none'; alert("Menunggu pesanan berikutnya...");}
function kembaliKePeta(){document.getElementById('detail-pesanan').style.display='none';}
function tandaiSampai(){alert("✅ Pesanan selesai diantar!"); document.getElementById('detail-pesanan').style.display='none';}

// FUNGSI CHAT
function bukaChat(t){tipeChatSekarang=t; document.getElementById('modal-chat').style.display='block'; isiContohPesan();}
function gantiTabChat(t){tipeChatSekarang=t; isiContohPesan();}
function isiContohPesan(){
    const kotak = document.getElementById('daftar-pesan');
    kotak.innerHTML = '';
    if(tipeChatSekarang==='pelanggan'){
        kotak.innerHTML = `
            <div class="pesan terima">Halo Mas, pesanannya sudah siap ya?<div class="waktu-pesan">19:40</div></div>
            <div class="pesan kirim">Siap Kak, saya sudah di depan restoran nih<div class="waktu-pesan">19:42</div></div>
        `;
    } else {
        kotak.innerHTML = `
            <div class="pesan terima">Silakan diambil Mas, pesanan nomor 5 ya<div class="waktu-pesan">19:41</div></div>
            <div class="pesan kirim">Baik terima kasih Bu<div class="waktu-pesan">19:42</div></div>
        `;
    }
}
function kirimPesan(){
    const input = document.getElementById('input-pesan');
    const teks = input.value.trim();
    if(!teks) return;
    const kotak = document.getElementById('daftar-pesan');
    const jam = new Date().getHours().toString().padStart(2,'0')+":"+new Date().getMinutes().toString().padStart(2,'0');
    kotak.innerHTML += `<div class="pesan kirim">${teks}<div class="waktu-pesan">${jam}</div></div>`;
    input.value='';
    kotak.scrollTop = kotak.scrollHeight;
    setTimeout(()=>{
        const balas = tipeChatSekarang==='pelanggan'?"Siap terima kasih!":"Terima kasih kembali!";
        kotak.innerHTML += `<div class="pesan terima">${balas}<div class="waktu-pesan">${jam}</div></div>`;
        kotak.scrollTop = kotak.scrollHeight;
    },1000);
}
function tutupChat(){document.getElementById('modal-chat').style.display='none';}
</script>

</body>
</html>
