<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daftar Resto Mitra</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }
        body {
            background: #f8f9fa;
            padding: 15px;
        }
        .box {
            background: white;
            border-radius: 12px;
            padding: 25px;
            max-width: 420px;
            margin: 20px auto;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        }
        .logo {
            text-align: center;
            font-size: 45px;
            margin-bottom: 8px;
        }
        h2 {
            text-align: center;
            color: #28a745;
            margin-bottom: 10px;
            font-size: 20px;
        }
        .deskripsi {
            text-align: center;
            color: #666;
            font-size: 14px;
            margin-bottom: 20px;
            line-height: 1.5;
        }
        label {
            font-weight: bold;
            margin-top: 12px;
            display: block;
            font-size: 14px;
            color: #333;
        }
        input, textarea, select {
            width: 100%;
            padding: 12px;
            margin-top: 6px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 15px;
            transition: 0.2s;
        }
        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: #28a745;
            box-shadow: 0 0 0 3px rgba(40,167,69,0.1);
        }
        button {
            width: 100%;
            padding: 14px;
            background: #28a745;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 18px;
            transition: 0.2s;
        }
        button:hover {
            background: #218838;
            transform: translateY(-1px);
        }
        .btn-kembali {
            background: #6c757d;
            margin-top: 10px;
        }
        .btn-kembali:hover {
            background: #5a6268;
        }
        .info {
            font-size: 13px;
            color: #666;
            margin-top: 15px;
            text-align: center;
            line-height: 1.5;
            background: #f8f9fa;
            padding: 10px;
            border-radius: 8px;
        }
    </style>
</head>
<body>

<div class="box">
    <div class="logo">🍛</div>
    <h2>PENDAFTARAN RESTO MITRA</h2>
    <p class="deskripsi">Daftarkan usaha kuliner Anda agar muncul di aplikasi pesanan</p>

    <label>Nama Lengkap Resto / Usaha</label>
    <input type="text" id="namaResto" placeholder="Contoh: Warung Makan Sederhana" required>

    <label>Nama Pemilik Usaha</label>
    <input type="text" id="namaPemilik" placeholder="Nama Pemilik Resto" required>

    <label>Nomor Telepon / HP Resto</label>
    <input type="tel" id="telpResto" placeholder="Contoh: 0812 3456 7890" required>

    <label>Alamat Lengkap Lokasi Resto</label>
    <textarea id="alamatResto" rows="2" placeholder="Jalan, Nomor, Desa/Kecamatan, Kota" required></textarea>

    <label>Jenis Kategori Kuliner</label>
    <select id="kategori">
        <option value="">-- Pilih Kategori --</option>
        <option>Masakan Tradisional</option>
        <option>Makanan Ringan & Jajanan</option>
        <option>Minuman Tradisional</option>
        <option>Oleh-oleh Khas Daerah</option>
    </select>

    <label>Buat Kata Sandi Admin Resto</label>
    <input type="password" id="sandiResto" placeholder="Minimal 6 karakter" required>

    <button onclick="daftarResto()">✅ DAFTARKAN RESTO SEKARANG</button>
    <button class="btn-kembali" onclick="window.location.href='beranda.html'">⬅️ Kembali ke Beranda</button>

    <div class="info">
        ℹ️ Setelah terdaftar: Nama, Alamat & Nomor Resto akan otomatis muncul di halaman pemesan dan aplikasi driver.
    </div>
</div>


<!-- KONEKSI FIREBASE -->
<script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-database-compat.js"></script>
<script>
const firebaseConfig = {
  apiKey: "AIzaSyA9lMH2uHFtuNsLinSZN-r2xxxxxx",
  authDomain: "kkn-kuliner-khas-nusantara.firebaseapp.com",
  databaseURL: "https://kkn-kuliner-khas-nusantara-default-rtdb.firebaseio.com",
  projectId: "kkn-kuliner-khas-nusantara",
  storageBucket: "kkn-kuliner-khas-nusantara.appspot.com",
  messagingSenderId: "121728270775",
  appId: "1:121728270775:web:3a3f8b5ad73xxxxxx"
};

firebase.initializeApp(firebaseConfig);
const db = firebase.database();

function daftarResto(){
    // AMBIL SEMUA NILAI INPUT
    const nama = document.getElementById('namaResto').value.trim();
    const pemilik = document.getElementById('namaPemilik').value.trim();
    const telp = document.getElementById('telpResto').value.trim();
    const alamat = document.getElementById('alamatResto').value.trim();
    const kategori = document.getElementById('kategori').value;
    const sandi = document.getElementById('sandiResto').value.trim();

    // VALIDASI DATA
    if(!nama || !pemilik || !telp || !alamat || !kategori || !sandi){
        return alert("⚠️ Lengkapi SEMUA data pendaftaran terlebih dahulu!");
    }
    if(sandi.length < 6){
        return alert("⚠️ Kata sandi minimal 6 karakter!");
    }

    // SIMPAN KE FIREBASE
    db.ref("DataResto").set({
        nama_resto: nama,
        nama_pemilik: pemilik,
        no_telp_resto: telp,
        alamat_resto: alamat,
        kategori: kategori,
        sandi_admin: sandi,
        status: "TERDAFTAR & AKTIF",
        tanggal_daftar: new Date().toLocaleString('id-ID')
    })
    .then(() => {
        alert("✅ PENDAFTARAN BERHASIL!\n\nData Resto sudah aktif dan siap dilayani pelanggan.");
        window.location.href = "pesan.html";
    })
    .catch(err => alert("❌ Gagal mendaftar: " + err.message));
}
</script>

</body>
</html>
