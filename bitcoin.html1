<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Harga Bitcoin Nyata - Simulasi</title>
    <style>
        * {margin:0; padding:0; box-sizing:border-box; font-family:Arial, sans-serif;}
        body {background:#0f172a; color:white; min-height:100vh; padding:20px;}
        .wadah {max-width:420px; margin:0 auto; background:#1e293b; border-radius:20px; padding:25px; box-shadow:0 0 30px rgba(247,147,26,0.2);}
        .judul {text-align:center; font-size:24px; font-weight:bold; color:#f7931a; margin-bottom:10px;}
        .sumber-data {text-align:center; font-size:12px; color:#94a3b8; margin-bottom:20px;}
        
        .kotak-harga {background:linear-gradient(135deg,#f7931a,#e67e22); border-radius:15px; padding:20px; text-align:center; margin-bottom:20px;}
        .label-harga {font-size:14px; opacity:0.9; margin-bottom:5px;}
        .angka-harga {font-size:32px; font-weight:bold;}
        .ubah-harga {font-size:16px; margin-top:8px; font-weight:bold;}
        .naik {color:#166534;}
        .turun {color:#991b1b;}
        
        .kotak-simulasi {background:#334155; border-radius:12px; padding:20px; margin-bottom:15px;}
        .judul-simulasi {font-size:16px; font-weight:bold; margin-bottom:15px; display:flex; align-items:center; gap:8px;}
        .lampu {width:12px; height:12px; border-radius:50%; background:#22c55e; animation:kedip 1s infinite;}
        @keyframes kedip {0%,100%{opacity:1;} 50%{opacity:0.3;}}
        .baris-status {display:flex; justify-content:space-between; padding:8px 0; font-size:14px; border-bottom:1px solid #475569;}
        .progres-bar {width:100%; height:10px; background:#475569; border-radius:5px; margin:15px 0; overflow:hidden;}
        .isi-progres {height:100%; background:linear-gradient(90deg,#f7931a,#fcd34d); width:0%; transition:1s;}
        .hasil-didapat {text-align:center; font-size:18px; font-weight:bold; color:#fcd34d; margin-top:10px;}
        
        .catatan-penting {background:rgba(239,68,68,0.1); border-left:4px solid #ef4444; padding:12px; border-radius:8px; font-size:13px; line-height:1.6; margin-top:15px;}
        .btn-muat {width:100%; padding:14px; background:#f7931a; border:none; border-radius:8px; font-size:16px; font-weight:bold; cursor:pointer; margin-top:10px;}
        .btn-muat:disabled {background:#78716c; cursor:not-allowed;}
    </style>
</head>
<body>
    <div class="wadah">
        <div class="judul">₿itcoin Harga Nyata</div>
        <div class="sumber-data">📊 Data dari pasar global (CoinGecko)</div>

        <!-- HARGA ASLI -->
        <div class="kotak-harga">
            <div class="label-harga">Harga Saat Ini</div>
            <div class="angka-harga" id="hargaBtc">Memuat...</div>
            <div class="ubah-harga" id="perubahanBtc">--</div>
        </div>

        <!-- SIMULASI KERJA -->
        <div class="kotak-simulasi">
            <div class="judul-simulasi"><span class="lampu"></span> Status: Berjalan (SIMULASI)</div>
            <div class="baris-status"><span>Kecepatan</span><span id="kecepatan">0 - 200 kH/s</span></div>
            <div class="baris-status"><span>Blok Ditemukan</span><span id="blok">0</span></div>
            <div class="baris-status"><span>Waktu Kerja</span><span id="waktu">00:00:00</span></div>
            
            <div class="progres-bar"><div class="isi-progres" id="progres"></div></div>
            <div class="hasil-didapat" id="hasil">Menunggu proses...</div>
        </div>

        <button class="btn-muat" id="tombolMulai" onclick="mulaiSimulasi()">🔄 Mulai Tampilan</button>

        <div class="catatan-penting">
            ⚠️ <strong>PERINGATAN PENTING:</strong><br>
            1. Harga di atas adalah data NYATA dari pasar dunia.<br>
            2. Bagian "penambangan" HANYA TAMPILAN CONTOH — TIDAK menghasilkan Bitcoin asli.<br>
            3. Penambangan asli butuh alat khusus mahal & listrik besar, tidak bisa lewat web.<br>
            4. Hati-hati penipuan: tidak ada cara mudah dapat Bitcoin gratis lewat halaman ini.
        </div>
    </div>

    <script>
        // AMBIL HARGA BITCOIN NYATA DARI API TERPERCAYA
        async function ambilHargaNyata() {
            try {
                const respon = await fetch('https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=idr&include_24hr_change=true');
                const data = await respon.json();
                
                const harga = data.bitcoin.idr;
                const ubah24jam = data.bitcoin.idr_24h_change;

                document.getElementById('hargaBtc').innerText = 'Rp ' + harga.toLocaleString('id-ID');
                
                const elemenUbah = document.getElementById('perubahanBtc');
                if (ubah24jam >= 0) {
                    elemenUbah.innerText = `↑ +${ubah24jam.toFixed(2)}% (24 Jam)`;
                    elemenUbah.className = 'ubah-harga naik';
                } else {
                    elemenUbah.innerText = `↓ ${ubah24jam.toFixed(2)}% (24 Jam)`;
                    elemenUbah.className = 'ubah-harga turun';
                }
            } catch (eror) {
                document.getElementById('hargaBtc').innerText = 'Gagal ambil data';
            }
        }

        let berjalan = false;
        let detik = 0;
        let nilaiProgres = 0;

        function mulaiSimulasi() {
            if (berjalan) return;
            berjalan = true;
            document.getElementById('tombolMulai').disabled = true;
            document.getElementById('tombolMulai').innerText = 'Sedang Berjalan...';

            // Perbarui harga nyata setiap 60 detik
            ambilHargaNyata();
            setInterval(ambilHargaNyata, 60000);

            // Jalankan simulasi tampilan
            setInterval(() => {
                detik++;
                let jam = Math.floor(detik / 3600);
                let menit = Math.floor((detik % 3600)/60);
                let dtk = detik % 60;
                document.getElementById('waktu').innerText = 
                    `${jam.toString().padStart(2,'0')}:${menit.toString().padStart(2,'0')}:${dtk.toString().padStart(2,'0')}`;

                nilaiProgres = (nilaiProgres + 1.5) % 100;
                document.getElementById('progres').style.width = nilaiProgres + '%';

                const acakKecepatan = Math.floor(Math.random() * 150) + 50;
                document.getElementById('kecepatan').innerText = acakKecepatan + ' kH/s';

                if (nilaiProgres < 1.5) {
                    document.getElementById('blok').innerText = parseInt(document.getElementById('blok').innerText) + 1;
                    document.getElementById('hasil').innerText = '≈ 0.00000012 BTC (SIMULASI)';
                    setTimeout(() => {
                        document.getElementById('hasil').innerText = 'Memproses blok berikutnya...';
                    }, 3000);
                }
            }, 1000);
        }

        // Ambil harga saat halaman dibuka
        ambilHargaNyata();
    </script>
</body>
</html>
